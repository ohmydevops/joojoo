{
    "name": "ohmydevops/joojoo",
    "description": "A lightweight multi-process web server built with PHP",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.79"
    },
    "scripts": {
        "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "cs:check": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.dist.php"
    }
}
